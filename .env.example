# Database
POSTGRES_URL=postgresql://postgres:password@localhost:5432/bkmk

# Authentication
# JWT Secret - generate with: openssl rand -base64 32
# This is used to sign session tokens
AUTH_SECRET=your-secret-key-here

# Google OAuth (optional)
# Get these from Google Cloud Console: https://console.cloud.google.com
# Create OAuth 2.0 Client ID credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# CORS Configuration for API access
# Set specific origins separated by commas, or leave as * for all origins
# Examples:
# CORS_ORIGINS=https://myapp.com,https://dashboard.example.com
# CORS_ORIGINS=*
CORS_ORIGINS=*
